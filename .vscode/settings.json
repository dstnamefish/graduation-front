{
  // 配置 EditorConfig 路径
  "editorconfig.configPath": "./config/.editorconfig",

  // 启用 Flat Config 模式的 ESLint
  "eslint.useFlatConfig": true,
  "eslint.validate": ["javascript", "typescript", "vue"],
  "eslint.run": "onType",
  "eslint.options": {
    "overrideConfigFile": "./eslint.config.mjs"
  },

  // Stylelint 适配多种前端样式文件
  "stylelint.validate": ["css", "scss", "sass", "less", "vue"],
  "stylelint.enable": true,
  "stylelint.configFile": "./stylelint.config.mjs",

  // 保存时自动格式化代码（使用 Prettier）
  "editor.formatOnSave": false,
  "prettier.configPath": "./prettier.config.mjs",
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  //  保存时自动修复 ESLint 和 Stylelint 错误
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit"
  },

  // 启用字符串中的快速建议（如内联样式、类名等）
  "editor.quickSuggestions": {
    "strings": true
  },

  // Prettier 设置（强制项目必须存在配置）
  "prettier.enable": true,
  "prettier.requireConfig": true,


  // 关闭 VS Code 自带 CSS 校验，避免和 Stylelint 冲突（可选）
  "css.validate": false,
  "scss.validate": false,

  // 禁用文件末尾自动添加换行符
  "files.insertFinalNewline": false,
  "files.trimTrailingWhitespace": true,
  "editor.trimAutoWhitespace": true,
  "cSpell.words": [
    "boxshadow",
    "funcs",
    "isabled",
    "ishidden",
    "Zen"
  ],

  // 隐藏特定文件夹
  "files.exclude": {
    "dist/": true,
    ".git/": true,
    "**/.DS_Store": false,
    "**/.hg": false,
    "**/.svn": false,
    "**/Thumbs.db": false
  },
  "trae.tab.enableRename": false,
  "trae.tab.enableAutoImport": false,
  "typescript.tsdk": "node_modules\\typescript\\lib",
  "search.exclude": {
    "**/*.code-search": false,
    "**/bower_components": false,
    "**/node_modules": false
  },
  "[svg]": {
    "editor.defaultFormatter": "jock.svg"
  },
  "svg.preview.background": "dark-transparent",
  "volar.autoCompleteRefs": false,
  "volar.codeLens.pugTools": false,
  "volar.codeLens.scriptSetupTools": false,
  "vue.inlayHints.missingProps": false,
  "vue.server.hybridMode": false,
  "git.ignoreLimitWarning": true
}
